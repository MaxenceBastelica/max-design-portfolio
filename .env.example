# Variables d'environnement (exemple)
# Copiez ce fichier en .env.local et ajoutez vos propres valeurs

# Email (Nodemailer avec Gmail)
# Pour obtenir un mot de passe d'application Gmail :
# 1. Allez sur https://myaccount.google.com/apppasswords
# 2. Connectez-vous à votre compte Gmail
# 3. Créez un nouveau mot de passe d'application
# 4. Copiez le mot de passe généré (16 caractères)
EMAIL_USER=votre-email@gmail.com
EMAIL_PASSWORD=votre-mot-de-passe-application

# Analytics (optionnel)
# NEXT_PUBLIC_GA_ID=your_google_analytics_id

# API URLs (si besoin)
# NEXT_PUBLIC_API_URL=https://your-api.com
